# ============================================================
# StockCompass 配置模板
# 复制为 .env 后填入实际值
# ============================================================

# --- Flask ---
FLASK_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret

# --- MySQL（与 StockShark 共用） ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=stock_analysis_system
DB_POOL_MIN=5
DB_POOL_MAX=20

# --- LLM Key 配置（三层独立） ---
#
# 【重要】各层使用独立的 LLM Key，不可共用：
#
# 1. DataAgent (localhost:8000):  使用独立的 DeepSeek Key 用于资讯清洗
#    → DATAAGENT_DEEPSEEK_API_KEY （在 DataAgent 项目的 .env 中配置）
#
# 2. StockShark (localhost:5000): 不使用 LLM（迁移后）
#
# 3. StockCompass (本项目):       使用 Doubao + DeepSeek 双 Key 进行综合分析
#    → DOUBAO_API_KEY  +  DEEPSEEK_API_KEY
#

# Doubao（火山引擎）— Compass 结构化分析用
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL_ID=

# DeepSeek — Compass 深度文章生成用（独立于 DataAgent 的 Key）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_ID=deepseek-reasoner

# --- WeChat Mini Program（可选）---
WX_APPID=
WX_SECRET=

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=/var/log/d8q

# --- Schedule ---
SCHEDULE_HOUR=17
SCHEDULE_MINUTE=0

# --- Session ---
SESSION_LIFETIME=86400
