# StockCompass 环境配置
FLASK_ENV=development
DEBUG=false
SECRET_KEY=change-this-in-production

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=stock_analysis_system
DB_POOL_MIN=5
DB_POOL_MAX=20

# LLM - Doubao (火山引擎)
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL_ID=

# LLM - DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_ID=deepseek-reasoner

# WeChat Mini Program
WX_APPID=
WX_SECRET=

# Logging
LOG_LEVEL=INFO
LOG_DIR=/var/log/d8q

# Schedule (daily analysis HH:MM)
SCHEDULE_HOUR=17
SCHEDULE_MINUTE=0

# Session (seconds, default 86400 = 1 day)
SESSION_LIFETIME=86400
